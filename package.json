{
  "name": "vite-plugin-wgsl-obfuscate",
  "version": "0.1.0",
  "description": "Vite plugin to obfuscate WGSL shader source in production builds",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "wgsl",
    "webgpu",
    "obfuscation",
    "minification",
    "shader"
  ],
  "author": "Redmond Riddell",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soaringred/vite-plugin-wgsl-obfuscate.git"
  },
  "bugs": {
    "url": "https://github.com/soaringred/vite-plugin-wgsl-obfuscate/issues"
  },
  "homepage": "https://github.com/soaringred/vite-plugin-wgsl-obfuscate#readme",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
